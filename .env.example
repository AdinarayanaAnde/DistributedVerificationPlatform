# Database
# For local development (default — no install needed):
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# For Docker / production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://appuser:apppass@db/dvf

# Security
SECRET_KEY=change-this-to-a-random-secret

# CORS (comma-separated origins, or * for all)
# For LAN development, set this to * or include your frontend origin, e.g.
# https://192.168.1.6:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# SMTP Notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Data Retention (industry best practice: 7-day rolling window, max 50 reports)
DATA_RETENTION_DAYS=7
PURGE_INTERVAL_HOURS=24
MAX_REPORT_COUNT=50
