# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicit text files
*.py        text diff=python
*.pyi       text diff=python
*.ts        text
*.tsx       text
*.js        text
*.jsx       text
*.json      text
*.css       text
*.scss      text
*.html      text
*.md        text diff=markdown
*.yml       text
*.yaml      text
*.toml      text
*.cfg       text
*.ini       text
*.txt       text
*.sh        text eol=lf
*.bat       text eol=crlf
Dockerfile  text
docker-compose*.yml text
Makefile    text eol=lf
LICENSE     text
.editorconfig text
.gitignore  text
.gitattributes text
.dockerignore text

# Binary files — never diff / never normalise
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.tar.gz    binary
*.db        binary
*.sqlite    binary
*.pem       binary

# Lock files — keep exact content, show text diffs
package-lock.json text -diff
